{
  "id": "sop-promotion",
  "name": "SOP Promotion Agent",
  "description": "Consume stabilized doc signals, promote mature procedures into SOPs, and keep the SOP index in sync.",
  "enabled": true,
  "order": 30,
  "task": {
    "id": "sop-promotion",
    "title": "Promote docs to SOP",
    "goal": "Read doc-maintenance promotion signals for the single-domain BFRL workspace, decide whether to create or update a domain SOP, and emit a machine-readable promotion result without modifying general docs.",
    "system_prompt_path": "system.md",
    "memory_paths": [
      "AGENT.md",
      "CLAUDE.md",
      "{meta_agent_doc_dir}/methodology.md",
      "{doc_dir}/project-overview.md",
      "{doc_dir}/domain-bfrl.md",
      "{doc_dir}/daily-doc-sop/INDEX.md",
      "{doc_dir}/daily-doc-sop/agent-runtime-architecture.md",
      "{doc_dir}/daily-doc-sop/main-orchestrator-design.md",
      "{doc_dir}/daily-doc-sop/runner-adapter-contract.md",
      "{doc_dir}/daily-doc-sop/daily-doc-sop-system-design.md",
      "{doc_dir}/daily-doc-sop/sop-promotion-agent-design.md"
    ],
    "allow_file_edits": true
  },
  "dependencies": [
    "doc-maintenance"
  ],
  "wakeup": {
    "watch_globs": [
      "agents/doc-maintenance/runtime/work-orders/*.json"
    ]
  },
  "launcher": {
    "kind": "codex",
    "config": {
      "session_style": "tool-loop",
      "max_turns": 8,
      "shell": "powershell",
      "usage_view": "raw",
      "prompt_mode": "trace",
      "background": false,
      "reasoning_effort": "medium"
    }
  },
  "paths": {
    "workspace_root": "../..",
    "runtime_root": "runtime",
    "launcher_root": "runtime/launchers"
  }
}
