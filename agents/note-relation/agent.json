    "memory_paths": [
      "../../AGENT.md",
      "../../CLAUDE.md",
      "../../meta-agent/doc/methodology.md",
      "../../memory/doc/project-overview.md",
      "../../memory/doc/domain-bfrl.md",
      "../../memory/doc/daily-doc-sop/INDEX.md",
      "../../memory/doc/daily-doc-sop/agent-runtime-architecture.md",
      "../../memory/doc/daily-doc-sop/main-orchestrator-design.md",
      "../../memory/doc/daily-doc-sop/runner-adapter-contract.md",
      "../../memory/doc/daily-doc-sop/daily-doc-sop-system-design.md",
      "../../memory/doc/daily-doc-sop/note-relation-agent-design.md"
    ],
    "allow_file_edits": true
  },
  "dependencies": [],
  "wakeup": {
    "watch_globs": [
      "memory/daily-notes/*.md"
    ]
  },
  "launcher": {
    "kind": "codex",
    "config": {
      "model": "gpt-5.4",
      "session_style": "tool-loop",
