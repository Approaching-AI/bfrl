{
  "id": "note-relation",
  "name": "Note Relation Agent",
  "description": "Triage newly arrived daily notes, assign relations, and emit one JSON work order per note.",
  "enabled": true,
  "order": 10,
  "task": {
    "id": "note-relation",
    "title": "Triage new daily notes",
